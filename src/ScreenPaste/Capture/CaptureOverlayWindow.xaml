<Window x:Class="ScreenPaste.Capture.CaptureOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="False"
        ShowInTaskbar="False"
        Topmost="True"
        Background="Black"
        Cursor="Cross"
        Focusable="True"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">

    <Grid x:Name="RootGrid">
        <!-- Everything below RootCanvas is authored in physical-pixel units; a
             ScaleTransform (1/dpi) is applied in code so it maps 1:1 to the capture. -->
        <Canvas x:Name="RootCanvas">
            <Image x:Name="ScreenImage" Canvas.Left="0" Canvas.Top="0"
                   RenderOptions.BitmapScalingMode="NearestNeighbor"/>

            <!-- Dark mask with the selection "punched out" (even-odd fill). -->
            <Path x:Name="MaskPath" Fill="#66000000" IsHitTestVisible="False"/>

            <!-- Hovered-window auto-detect outline (selection phase). -->
            <Rectangle x:Name="DetectBorder" Visibility="Collapsed" IsHitTestVisible="False"
                       Stroke="#3DA9FC" StrokeThickness="2" StrokeDashArray="4 2"/>

            <!-- The editing surface, positioned/sized to the selection in code. -->
            <Canvas x:Name="EditLayer" ClipToBounds="True" Visibility="Collapsed">
                <Canvas x:Name="BlurHost"/>
                <Canvas x:Name="ShapeHost" Canvas.Left="0" Canvas.Top="0"/>
                <Canvas x:Name="StickerHost" Canvas.Left="0" Canvas.Top="0"/>
                <!-- Focusable=False: InkCanvas class-binds Ctrl+C/X/V for stroke editing;
                     if it ever takes keyboard focus, it swallows our Copy/Save hotkeys. -->
                <InkCanvas x:Name="Ink" Background="Transparent" Focusable="False"
                           Canvas.Left="0" Canvas.Top="0"/>
                <Canvas x:Name="TextHost" Canvas.Left="0" Canvas.Top="0"/>
                <Rectangle x:Name="InteractionLayer" Fill="#01000000"
                           IsHitTestVisible="False" Canvas.Left="0" Canvas.Top="0"/>
            </Canvas>

            <!-- Live selection rectangle border. -->
            <Rectangle x:Name="SelectionBorder" Visibility="Collapsed" IsHitTestVisible="False"
                       Stroke="#3DA9FC" StrokeThickness="1.5"/>

            <!-- Size readout chip. -->
            <Border x:Name="SizeReadout" Visibility="Collapsed" IsHitTestVisible="False"
                    Background="#CC1E1E1E" CornerRadius="3" Padding="8,3">
                <TextBlock x:Name="SizeText" Foreground="White" FontSize="14" FontFamily="Consolas"
                           HorizontalAlignment="Center"/>
            </Border>

            <!-- Selection resize handles (editing phase): 4 corners + 4 edge midpoints. -->
            <Canvas x:Name="HandleLayer" Visibility="Collapsed"/>

            <!-- Pixel magnifier + colour readout: follows the cursor while framing the
                 region and while dragging the resize handles / moving the region. -->
            <StackPanel x:Name="Magnifier" Visibility="Collapsed" IsHitTestVisible="False">
                <Border BorderBrush="White" BorderThickness="1" Background="Black">
                    <Grid Width="180" Height="132">
                        <Image x:Name="MagImage" Stretch="Fill"
                               RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                        <Canvas>
                            <!-- Crosshair in four segments that stop at the centre cell,
                                 so the inspected pixel keeps its true colour. -->
                            <Rectangle x:Name="MagCrossT" Width="6" Fill="#503DA9FC"/>
                            <Rectangle x:Name="MagCrossB" Width="6" Fill="#503DA9FC"/>
                            <Rectangle x:Name="MagCrossL" Height="6" Fill="#503DA9FC"/>
                            <Rectangle x:Name="MagCrossR" Height="6" Fill="#503DA9FC"/>
                            <Rectangle x:Name="MagCenter" Width="6" Height="6"
                                       Stroke="White" StrokeThickness="1"/>
                        </Canvas>
                    </Grid>
                </Border>
                <Border Background="#CC1E1E1E" Padding="8,6,8,7" Width="182">
                    <StackPanel>
                        <TextBlock x:Name="MagPos" Foreground="White" FontSize="13" FontFamily="Consolas"
                                   HorizontalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0" HorizontalAlignment="Center">
                            <Rectangle x:Name="MagSwatch" Width="13" Height="13"
                                       Stroke="#66FFFFFF" StrokeThickness="1" VerticalAlignment="Center"/>
                            <TextBlock x:Name="MagColor" Foreground="White" FontSize="13"
                                       FontFamily="Consolas" Margin="6,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock x:Name="MagHint1" Foreground="#CCFFFFFF" FontSize="11" Margin="0,4,0,0"
                                   HorizontalAlignment="Center"/>
                        <TextBlock x:Name="MagHint2" Foreground="#CCFFFFFF" FontSize="11"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Floating toolbar (built/positioned in code). NOTE: no DropShadowEffect
                 here — a WPF Effect rasterizes the whole subtree into an intermediate
                 bitmap, which kills ClearType and blurs every label. -->
            <Border x:Name="Toolbar" Visibility="Collapsed"
                    Background="#F2222222" CornerRadius="6" Padding="6"
                    BorderBrush="#55FFFFFF" BorderThickness="1">
                <StackPanel x:Name="ToolbarStack" Orientation="Vertical"/>
            </Border>
        </Canvas>
    </Grid>
</Window>
