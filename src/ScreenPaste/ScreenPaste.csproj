<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net9.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <AssemblyName>ScreenPaste</AssemblyName>
    <RootNamespace>ScreenPaste</RootNamespace>
    <LangVersion>latest</LangVersion>
  </PropertyGroup>

  <!-- Keep WinForms/Drawing OUT of the implicit global usings so WPF types
       (Color, Point, Button, MouseEventArgs, …) resolve unambiguously.
       The two files that need GDI+ import System.Drawing explicitly. -->
  <ItemGroup>
    <Using Remove="System.Windows.Forms" />
    <Using Remove="System.Drawing" />
  </ItemGroup>

</Project>
